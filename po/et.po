"\n"
"    $rsearch(disc: 1,disc: \\(\\\\d+\\)) => \"1\"\n"
"    $rsearch(disc: 2,\\(\\\\w+\\): \\(\\\\d+\\),1) => \"disc\"\n"
"    $rsearch(disc: 3,\\(\\\\w+\\): \\(\\\\d+\\),2) => \"3\"\n"
"    $rsearch(disc: 4,disc: \\(?P<disc>\\\\d+\\),disc) => \"4\"\n"
"    $rsearch(disc: none,disc\\(: \\\\d+\\)?) => \"disc\"\n"
"    $rsearch(disc: /5,disc: \\(\\\\d+\\)?/\\\\d+,1) => \"\"\n"
"\n"
